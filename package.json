{
  "name": "gym-ver2-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean:next": "node -e \"const fs=require('fs'); fs.rmSync('.next',{recursive:true,force:true});\"",
    "dev": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --turbopack",
    "build": "node --max-old-space-size=8192 node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/nextjs-registry": "^1.0.2",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@reduxjs/toolkit": "^2.9.1",
    "antd": "^5.27.5",
    "axios": "^1.11.0",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^15.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.14",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.2"
  }
